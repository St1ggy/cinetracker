## 8. API routes pattern

```typescript
// src/routes/api/something/+server.ts
import { json, error } from '@sveltejs/kit'
import { z } from 'zod'
import { listsRepository } from '$lib/server/repositories'

export const GET = async ({ locals, params, url }) => {
  const session = await locals.auth()
  if (!session?.user?.id) throw error(401, 'Authentication required')

  const parsed = schema.parse(Object.fromEntries(url.searchParams))
  const result = await listsRepository.findSomething(parsed)

  return json(result)
}
```

**Never use `prisma.*` directly in routes** — always go through `src/lib/server/repositories/`.

