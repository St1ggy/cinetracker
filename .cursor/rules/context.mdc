## 5. Database schema (key models)

```prisma
model User       { id, name, email, emailVerified, image, ... }
model Account    { Auth.js OAuth account }
model Session    { Auth.js session }
model List       { id, title, description, visibility: ListVisibility, ownerId, ... }
model SavedList  { userId, listId }
model ListItem   {
  id, listId, mediaId
  status: WatchStatus?          // default PLAN_TO_WATCH
  currentSeason: Int?
  currentEpisode: Int?
}
model Media      { id, externalId, provider: MediaProvider, mediaType: MediaType,
                   title, originalTitle, overview, posterUrl, backdropUrl, year,
                   runtimeMinutes, seasonBreakdown: Json,
                   episodeRuntimeMin, episodeRuntimeMax, seasonsCount, episodesCount,
                   countries: String[], genres→MediaGenre, cast→MediaCast, sources→MediaSource }
model UserApiKey { userId, provider: MediaProvider, credentials: Json (encrypted) }

enum WatchStatus    { WATCHED, IN_PROGRESS, PLAN_TO_WATCH }
enum MediaType      { MOVIE, TV, ANIME, CARTOON, OTHER }
enum MediaProvider  { TMDB, ANILIST, OMDB, TVDB, JIKAN, KITSU, TRAKT }
enum ListVisibility { PUBLIC, UNLISTED, PRIVATE }
```

