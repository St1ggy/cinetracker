## 6. Svelte 5 (runes) — critical rules

```svelte
<script lang="ts">
  // Page data — always via page.state, not $props()
  import { page } from '$app/state'
  const data = $derived(page.data as PageData)   // reactive

  // State
  let count = $state(0)
  const double = $derived(count * 2)

  // Props
  type Props = { title: string; items?: string[] }
  const { title, items = [] }: Props = $props()

  // Props that should only initialize once from a reactive source — wrap in untrack()
  let value = $state(untrack(() => data.someField ?? ''))

  // ❌ NEVER Svelte 4: writable, $store, on:click, let:prop
</script>
```

**`{@const}` only inside block-level tags** (`{#each}`, `{#if}`, `{#snippet}`), never inside HTML elements.

