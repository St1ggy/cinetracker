{
  "name": "cinetracker",
  "version": "1.21.0",
  "packageManager": "bun@1.2.12",
  "devDependencies": {
    "@eslint/compat": "^2.0.5",
    "@eslint/js": "^10.0.1",
    "@inlang/paraglide-js": "^2.16.1",
    "@internationalized/date": "^3.12.1",
    "@lucide/svelte": "^1.11.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@st1ggy/linter-config": "^6.3.2",
    "@sveltejs/adapter-vercel": "^6.3.3",
    "@sveltejs/kit": "^2.58.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^25",
    "bits-ui": "^2.18.0",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "dotenv": "^17.4.2",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.17.1",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "mdsvex": "^0.12.7",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.7.3",
    "semantic-release": "^25.0.3",
    "stylelint": "^17.9.0",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.6",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.10",
    "vite-plugin-devtools-json": "^1.0.0",
    "vitest": "^4.1.5"
  },
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "husky",
    "check": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test": "vitest run",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:baseline": "node scripts/baseline-migrations.js",
    "prisma:push": "prisma db push",
    "release": "semantic-release",
    "prepare-to-prod": "bunx semantic-release --no-ci",
    "release:trigger": "node scripts/trigger-release.js"
  },
  "type": "module",
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@auth/sveltekit": "^1.11.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tanstack/svelte-query": "^6.1.24",
    "clsx": "^2.1.1",
    "css-fade": "^1.0.9",
    "dompurify": "^3.4.1",
    "embla-carousel": "^8.6.0",
    "mode-watcher": "^1.1.0",
    "pg": "^8.20.0",
    "prisma": "^7.8.0",
    "svelte-dnd-action": "^0.9.69",
    "svelte-sonner": "^1.1.1",
    "unstorage": "^1.17.5",
    "zod": "^4.3.6"
  },
  "trustedDependencies": [
    "@st1ggy/linter-config",
    "esbuild",
    "unrs-resolver"
  ],
  "lint-staged": {
    "*.{ts,svelte}": "eslint"
  }
}
